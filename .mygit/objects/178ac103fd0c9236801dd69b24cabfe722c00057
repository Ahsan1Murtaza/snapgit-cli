#include "StatusHandler.h"
#include "../../Helper/RepoCheck/RepoCheck.h"
#include "../../Helper/GetCurrentCommitHash/GetCurrentCommitHash.h"
#include "../../Helper/Hash/Hash.h"
#include <iostream>
#include <filesystem>
#include <fstream>
#include <unordered_map>

using namespace std;
namespace fs = std::filesystem;

void StatusHandler::showStatus() {
    if (!RepoCheck::isRepoInitialized()) {  // ✅ use direct function from RepoCheck
        cout << "fatal: not a snapgit repository\n";
        return;
    }

    cout << "=== SnapGit Status ===\n";

    // Load index (staging area)
    unordered_map<string, string> indexMap;
    ifstream indexFile(".mygit/index");
    string filename, hash;
    while (indexFile >> filename >> hash)  // ✅ correct order: filename first, then hash
        indexMap[filename] = hash;
    indexFile.close();

    // Get latest commit
    string commitHash = getCurrentCommitHash();
    unordered_map<string, string> commitFiles;

    if (!commitHash.empty()) {
        string commitPath = ".mygit/commits/" + commitHash;
        ifstream cfile(commitPath);
        string line;
        bool fileListSection = false;
        while (getline(cfile, line)) {
            if (line == "files:") { fileListSection = true; continue; }
            if (fileListSection && !line.empty()) {
                size_t spacePos = line.find(' ');
                if (spacePos != string::npos)
                    commitFiles[line.substr(spacePos + 1)] = line.substr(0, spacePos);
            }
        }
        cfile.close();
    }

    // 1️⃣ Check for unstaged changes
    cout << "\nChanges not staged for commit:\n";
    for (auto& [file, idxHash] : indexMap) {
        if (!fs::exists(file)) {
            cout << "  deleted: " << file << "\n";
        } 
        else if (fs::is_regular_file(file)) {  // <-- only hash regular files
            string currentHash = Hash::sha1(file);
            if (currentHash != idxHash)
                cout << "  modified: " << file << "\n";
        }
    }

    // 2️⃣ Check for untracked files
    cout << "\nUntracked files:\n";
    for (auto& entry : fs::directory_iterator(".")) {
        string f = entry.path().filename().string();
        if (f == ".mygit") continue;
        if (!indexMap.count(f))
            cout << "  " << f << "\n";
    }

    // 3️⃣ Show staged but uncommitted
    cout << "\nChanges to be committed:\n";
    for (auto& [file, idxHash] : indexMap) {
        if (!commitFiles.count(file))
            cout << "  new file: " << file << "\n";
        else if (commitFiles[file] != idxHash)
            cout << "  modified: " << file << "\n";
    }
}
