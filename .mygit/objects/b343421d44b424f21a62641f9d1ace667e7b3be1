#include "AddHandler.h"
#include <filesystem>
#include <iostream>
#include <fstream>
#include "../../Helper/Hash/Hash.h"  // Your SHA-1 implementation

using namespace std;
namespace fs = std::filesystem;

void AddHandler::handleAdd(const string& path) {
    if (path == ".") {
        // Recursively add all files in the repo
        for (const auto& entry : fs::recursive_directory_iterator(fs::current_path())) {
            if (entry.is_regular_file()) {
                string filePath = entry.path().string();

                // Skip .mygit directory
                if (filePath.find(".mygit") == string::npos) {
                    stageFile(filePath);
                }
            }
        }
    } else {
        stageFile(path);
    }
}

void AddHandler::stageFile(const string& filePath) {
    // Check file existence
    if (!fs::exists(filePath)) {
        cerr << "Error: File " << filePath << " does not exist.\n";
        return;
    }

    // Compute SHA-1 hash
    string hash = Hash::sha1(filePath);
    if (hash.empty()) {
        cerr << "Error: Could not compute hash for " << filePath << endl;
        return;
    }

    // Ensure objects directory exists
    fs::create_directories(".mygit/objects");

    // Copy file to objects using hash as filename
    fs::path objectPath = ".mygit/objects/" + hash;
    if (!fs::exists(objectPath)) {
        fs::copy_file(filePath, objectPath, fs::copy_options::overwrite_existing);
    }

    // Add to index
    ofstream indexFile(".mygit/index", ios::app);
    if (!indexFile.is_open()) {
        cerr << "Error: Could not open index file\n";
        return;
    }

    indexFile << filePath << " " << hash << "\n";
    indexFile.close();

    cout << "Added: " << filePath << endl;
}

